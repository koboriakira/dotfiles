{
  // グローバルショートカットキー
  "globalShortcut": "Shift+Alt+Space",

  // MCP (Model Context Protocol) サーバー設定
  "mcpServers": {
    // Draw.io: ダイアグラム作成用MCPサーバー
    "drawio": {
      "command": "npx",
      "args": ["@drawio/mcp"]
    },
    // GitHub: GitHub操作用MCPサーバー（Docker経由）
    "github": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_GITHUB_PAT>" // GitHub PATに置き換える
      }
    }
  },

  // Claude Desktop のユーザー設定
  "preferences": {
    // メニューバーアイコンの表示
    "menuBarEnabled": false,
    // Cowork（スケジュールタスク）の有効化
    "coworkScheduledTasksEnabled": false,
    // サイドバーのモード（"code" | "chat"）
    "sidebarMode": "chat",
    // 権限バイパスモード（確認なしでツール実行）
    "bypassPermissionsModeEnabled": true
  }
}
