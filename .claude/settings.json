{
  "env": {
    "NODE_ENV": "development",
    "PYTHONPATH": ".",
    "EDITOR": "code",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(git *)",
      "Bash(pip *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:developer.mozilla.org)",
      "mcp__fetch__*"
    ],
    "deny": [
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(/etc/**)",
      "Edit(~/.zshrc)",
      "Edit(~/.bashrc)",
      "Bash(git rebase :*)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(dd *)",
      "Read(**/Pods/**)",
      "Read(**/.claude/worktrees/**)",
      "Read(**/DerivedData/**)",
      "Read(**/node_modules/**)",
      "Read(**/.build/**)",
      "Read(**/__pycache__/**)",
      "Read(**/*.egg-info/**)",
      "Read(**/.venv/**)",
      "Read(**/.next/**)",
      "Read(**/out/**)",
      "Read(**/dist/**)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message 'Ready for input' -sound default"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message 'Permission required' -sound Ping"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message 'Task completed' -sound Hero"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "language": "Japanese",
  "skipDangerousModePermissionPrompt": true,
  "workflow": {
    "autoApprove": true,
    "confirmBeforeRun": false,
    "maxIterations": 20,
    "dangerousOperationsOnly": true
  },
  "memory": {
    "enableAutoLoad": true,
    "recursiveSearch": true,
    "maxDepth": 10,
    "defaultMemoryLocation": "user"
  }
}
