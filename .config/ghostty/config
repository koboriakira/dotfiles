# Ghostty 設定ファイル
# 参考: https://zenn.dev/sprix_it/articles/a25ddd0ca4d175

# 起動時にウィンドウを最大化
maximize = true

# JIS キーボード対応: タブ移動のキーバインドをスワップ
# JIS キーボードでは [ と ] のキーコードが US 配列と逆になるため、
# Cmd+Shift+[ / Cmd+Shift+] でのタブ移動が直感と逆になる。
# アクションをスワップすることで、見た目通りの方向にタブ移動できる。
keybind = super+shift+bracket_left=next_tab
keybind = super+shift+bracket_right=previous_tab

# vimライクなペイン移動（Ctrl+hjkl）
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right
keybind = ctrl+a>f=toggle_split_zoom
keybind = ctrl+a>e=equalize_splits

# Ctrl+M で Enter 送信
# Ctrl+M は本来キャリッジリターン（\r）を送信するキーだが、
# 環境によっては期待通りに動かないことがある。明示的に設定。
keybind = ctrl+m=text:\r

# デスクトップ通知を有効化
desktop-notifications = true

# ベル通知: タイトルバー変更 + ウィンドウのアテンション要求
bell-features = title,attention

# 非フォーカスペインの視覚的区別
unfocused-split-opacity = 0.7
unfocused-split-fill = #1e2030
split-divider-color = #7aa2f7
focus-follows-mouse = true

font-size = 18

macos-option-as-alt = left
